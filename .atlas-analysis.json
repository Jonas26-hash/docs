  "keyFeatures": [
    "Patient records management with medical history, insurance, and allergies",
    "Appointment scheduling with doctor and patient assignment",
    "Medical consultations with diagnosis and treatment documentation",
    "Prescription issuance and dispensation tracking",
    "Pharmacy inventory management with low-stock alerts",
    "Billing and charge tracking per patient",
    "Notification system with EMAIL and SMS channels",
    "Role-based access control with 6 distinct roles (ADMIN, DOCTOR, FARMACEUTICO, ATENCION_CLIENTE, CAJERO, PACIENTE)",
    "JWT-based authentication (RS256) with 24-hour token lifetime",
    "Single API Gateway entry point on port 8080 with circuit breaker resilience"
  ],
